# NovelRyt environment configuration.
# Copy to `.env` and fill in. ALL VALUES ARE OPTIONAL for local-first mode —
# the app runs fully offline against IndexedDB with no cloud configuration.

# --- Firebase (optional; enables cloud sync + Google auth) ---
# Leave blank to run in local-only mode (default).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- AI (Gemini) ---
# AI keys are SERVER-SIDE only. They are NOT a Vite/client variable.
# Set them as a Cloudflare secret named GEMINI_API_KEYS (comma/newline-separated)
# on the Pages project, or for local Functions dev create a `.dev.vars` file:
#   GEMINI_API_KEYS=key1,key2,key3
# Then run `npx wrangler pages dev -- npm run dev`. See docs/DEPLOYMENT.md.
