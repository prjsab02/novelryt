# NovelRyt environment configuration.
# Copy to `.env` and fill in. ALL VALUES ARE OPTIONAL for local-first mode —
# the app runs fully offline against IndexedDB with no cloud configuration.

# --- Firebase (optional; enables cloud sync + Google auth) ---
# Leave blank to run in local-only mode (default).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- AI (optional; Gemini API keys can also be entered in-app under Settings) ---
# Keys configured in-app are stored locally and take precedence. This is a
# convenience default for development only. NEVER commit real keys.
VITE_GEMINI_API_KEYS=
